# Hetzner host planning template only.
# Do not commit real values.

# Host identity
HETZNER_SERVER_NAME=chillywood-prod-01
HETZNER_SERVER_IPV4=87.99.145.160
SSH_BOOTSTRAP_USER=chillywood
SSH_PORT=22
SERVER_TIMEZONE=UTC
PUBLIC_BASE_DOMAIN=chillywoodstream.com
CADDY_ACME_EMAIL=ops@example.com
CHILLYWOOD_APP_ROOT=/opt/chillywood
CHILLYWOOD_LOG_ROOT=/var/log/chillywood

# Realtime ingress
LIVEKIT_PUBLIC_HOST=live.chillywoodstream.com
LIVEKIT_URL=wss://live.chillywoodstream.com
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

# Static public surfaces
STATUS_PUBLIC_HOST=status.example.com
LEGAL_PUBLIC_HOST=live.chillywoodstream.com

# Monitoring / logging
HOST_LOG_LEVEL=info
OPS_ALERT_EMAIL=ops@example.com
LOG_RETENTION_DAYS=7

# Provider token stays out of repo.
# Export it only in a local shell/session if later automation is intentionally used.
# HETZNER_API_TOKEN=not-committed
