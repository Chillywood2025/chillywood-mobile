# Hetzner host planning template only.
# Do not commit real values.

# Host identity
SERVER_TIMEZONE=UTC
PUBLIC_BASE_DOMAIN=example.com
CADDY_ACME_EMAIL=ops@example.com

# Realtime ingress
LIVEKIT_PUBLIC_HOST=realtime.example.com
LIVEKIT_URL=wss://realtime.example.com
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

# Optional static public surfaces later
STATUS_PUBLIC_HOST=status.example.com
LEGAL_PUBLIC_HOST=legal.example.com

# Monitoring / logging
HOST_LOG_LEVEL=info
OPS_ALERT_EMAIL=ops@example.com
LOG_RETENTION_DAYS=7
