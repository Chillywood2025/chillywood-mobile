# Copy to .env and fill in values before running Maestro locally.

# Current Expo session URL for Maestro deep links.
# Set this to the URL printed by the active Expo session.
EXPO_URL=exp://127.0.0.1:8084

# Bundle ID — default is Expo Go on iOS / Android.
CHILLYWOOD_APP_ID=host.exp.exponent

# Optional: flow 09 expects the authenticated user's profile id.
SELF_PROFILE_USER_ID=
