# Copy to .env and fill in values before running against a dev build or real device.

# Bundle ID — default is Expo Go on iOS / Android.
# For a dev build change to your real bundle identifier, e.g.:
#   CHILLYWOOD_APP_ID=com.yourorg.chillywood
CHILLYWOOD_APP_ID=host.exp.exponent

# Optional: provide a live Watch-Party room code to test flow 04 against a real room.
# Leave blank to test the Watch Party hub/index screen only.
PARTY_ROOM_ID=
